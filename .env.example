# ============================================================
# Claw Personal / NanoClaw — Miljøvariabler
# ============================================================
# VIKTIG: Kopier denne filen til .env og fyll inn ekte verdier.
#         .env skal ALDRI committes til versjonskontroll!
# ============================================================

# Anthropic API-nøkkel (ekte Claude API-nøkkel)
# Hentes fra: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX

# LiteLLM Master Key — admin-nøkkel for å opprette Virtual Keys.
# Generer en sterk, unik nøkkel med:
#   openssl rand -hex 32
LITELLM_MASTER_KEY=sk-clawpersonal-XXXXXXXXXXXXXXXX

# Fremtidig: Google API-nøkkel for Gemini-modeller (valgfritt)
# GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXX

# ============================================================
# Orkestrator (Fase 2) — Backend for "Zero Delay" onboarding
# ============================================================

# Port for Orkestrator-serveren (Express)
ORCHESTRATOR_PORT=3000

# Docker-image for NanoClaw brukercontainere
NANOCLAW_IMAGE=nanoclaw-base:latest

# Fremtidig: Budsjett per bruker i USD (for LiteLLM kostnadskontroll)
# USER_BUDGET=10
# BUDGET_DURATION=30d
