# ============================================================
# Claw Personal / NanoClaw — Miljøvariabler
# ============================================================
# VIKTIG: Kopier denne filen til .env og fyll inn ekte verdier.
#         .env skal ALDRI committes til versjonskontroll!
# ============================================================

# Anthropic API-nøkkel (ekte Claude API-nøkkel)
# Hentes fra: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX

# LiteLLM Master Key — admin-nøkkel for å opprette Virtual Keys.
# Generer en sterk, unik nøkkel med:
#   openssl rand -hex 32
LITELLM_MASTER_KEY=sk-clawpersonal-XXXXXXXXXXXXXXXX

# Fremtidig: Google API-nøkkel for Gemini-modeller (valgfritt)
# GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXX

# ============================================================
# Orkestrator (Fase 2) — Backend for "Zero Delay" onboarding
# ============================================================

# Port for Orkestrator-serveren (Express)
ORCHESTRATOR_PORT=3000

# Docker-image for NanoClaw brukercontainere
NANOCLAW_IMAGE=nanoclaw-base:latest

# Fremtidig: Budsjett per bruker i USD (for LiteLLM kostnadskontroll)
# USER_BUDGET=10
# BUDGET_DURATION=30d

# ============================================================
# Fase 3: Google OAuth — «Magic Connect» Onboarding
# ============================================================
# Opprett credentials i Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
#
# Krever aktiverte API-er:
#   - Gmail API
#   - Google Calendar API
#   - YouTube Analytics API
#   - YouTube Data API v3
# ============================================================

# OAuth 2.0 Client ID (type: Web application)
GOOGLE_CLIENT_ID=xxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ============================================================
# Session & Sikkerhet
# ============================================================

# Sesjonshemmelighet for express-session (CSRF-beskyttelse under OAuth)
# Generer med: openssl rand -hex 32
SESSION_SECRET=generer-en-sterk-hemmelighet-her

# ============================================================
# The Vault — Zero-Knowledge Kryptering
# ============================================================
# Master Key brukes til å avlede unike per-bruker krypteringsnøkler.
# ALDRI del denne nøkkelen. Hvis den mistes, kan ingen tokens dekrypteres.
# Generer med: openssl rand -hex 32
VAULT_MASTER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Fase 4: Database & State Management (PostgreSQL)
# ============================================================
POSTGRES_USER=claw_admin
POSTGRES_PASSWORD=skriv-et-sikkert-passord-her
POSTGRES_DB=claw_db

# Connection string brukt av Orkestratoren for å koble til DB:
# (Bruk 'db' som nettverksnavn når det kjører internt i docker)
DATABASE_URL=postgresql://claw_admin:skriv-et-sikkert-passord-her@db:5432/claw_db

# ============================================================
# Fase 5: Stripe Betalingsintegrasjon
# ============================================================
# Hent disse verdiene fra Stripe Dashboard:
#   https://dashboard.stripe.com/apikeys
#   https://dashboard.stripe.com/webhooks
#
# Test-modus: Bruk sk_test_... og whsec_... under utvikling.
# Produksjon: Bytt til sk_live_... og tilhørende webhook secret.
# ============================================================

# Stripe hemlig API-nøkkel (ALDRI eksponer til klientside!)
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stripe Webhook Signing Secret (fra Stripe Dashboard → Webhooks)
# Generes automatisk når du registrerer webhook-URL-en din.
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stripe Price ID for Claw Personal abonnementet
# Opprett et produkt i Stripe Dashboard og kopier price_... ID-en.
STRIPE_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Redirect-URLer etter betaling (oppdater til produksjonsdomene)
# Fase 8: Brukeren sendes til /dashboard (ikke /magic-connect) etter betaling.
# Google Auth er nå valgfritt og initieres fra dashbordet.
STRIPE_SUCCESS_URL=https://app.clawpersonal.no/dashboard
STRIPE_CANCEL_URL=https://app.clawpersonal.no/

# ============================================================
# Fase 6: Frontend Portal ("The Gateway")
# ============================================================

# Frontend URL — brukes av Orkestratoren for CORS og OAuth-redirect
FRONTEND_URL=http://localhost:3001

# Frontend port (Docker-containerens port)
FRONTEND_PORT=3001

# API URL — brukes av frontenden for å kontakte Orkestratoren
# I Docker: bruk container-navn. Lokalt: bruk localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
